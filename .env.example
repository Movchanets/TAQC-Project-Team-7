# GreenCity E2E Test Configuration
# Copy this file to .env and fill in your values: cp .env.example .env

# Base URL of the GreenCity application
BASE_URL=https://www.greencity.cx.ua

# Run tests in headless mode (true/false)
HEADLESS=true

# Number of retries on test failure
RETRIES=0

# Global test timeout in milliseconds
TIMEOUT=30000

# Test user credentials (required for authenticated tests)
LOGIN_EMAIL=
LOGIN_PASSWORD=
