{
  "name": "greencity-e2e-tests",
  "version": "1.0.0",
  "description": "E2E test automation framework for GreenCity platform using Playwright, TypeScript, POM, and Allure reporting.",
  "main": "index.js",
  "directories": {
    "test": "tests"
  },
  "scripts": {
    "test": "npx playwright test --project=chromium",
    "test:all": "npx playwright test",
    "test:headed": "npx playwright test --project=chromium --headed",
    "test:debug": "npx playwright test --project=chromium --debug",
    "test:ui": "npx playwright test --ui",
    "report": "npx allure generate allure-results -o allure-report --clean && npx allure open allure-report",
    "report:ci": "npx allure generate allure-results -o allure-report --clean",
    "report:open": "npx allure open allure-report",
    "playwright:install": "npx playwright install --with-deps"
  },
  "keywords": [
    "playwright",
    "e2e",
    "testing",
    "greencity",
    "allure"
  ],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@types/node": "^25.6.0",
    "allure": "^3.8.2",
    "allure-playwright": "^3.9.0",
    "typescript": "^5.9.3"
  },
  "dependencies": {
    "dotenv": "^17.4.2"
  }
}
